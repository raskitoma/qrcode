# --- Web Application Configuration ---
# The host port where the application will be accessible
HOST_PORT=8060

# --- QR Code Generation Settings ---
# Base resolution of the QR modules (Higher = Sharper)
PIXEL_WIDTH=20
# Default Foreground and Background colors
FG_COLOR=#000000
BG_COLOR=#ffffff

# --- Branding & Logos ---
# Paths to your custom logos (relative to app directory or full URLs)
# Defaults to Raskitoma brand logos
LOGO_DARK_URL=/img/rask_logo-white.svg
LOGO_LIGHT_URL=/img/rask_logo-black.svg

# --- System Settings ---
TZ=America/Guayaquil
PUID=1000
PGID=1000
